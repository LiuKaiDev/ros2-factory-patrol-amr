          <material>
            <ambient>0.000 0.000 0.000 1</ambient>
            <diffuse>0.000 0.000 0.000 1</diffuse>
            <emissive>0 0 0 1</emissive>
            <double_sided>true</double_sided>
          </material>
        </visual>
      </link>
    </model>
    <model name="label_obstacle_clear_status">
      <static>false</static>
      <pose>0.65 3.65 -2 0 0 0.00</pose>
      <link name="link">
        <gravity>false</gravity>
        <visual name="text_mesh_visual">
          <cast_shadows>false</cast_shadows>
          <geometry><mesh><uri>../media/text_meshes/label_obstacle_clear_status.obj</uri></mesh></geometry>
          <material>
            <ambient>0.000 0.000 0.000 1</ambient>
            <diffuse>0.000 0.000 0.000 1</diffuse>
            <emissive>0 0 0 1</emissive>
            <double_sided>true</double_sided>
          </material>
        </visual>
      </link>
    </model>
    <!-- END AMR_STATUS_LABEL_MODELS -->

    <model name="mobile_robot">
      <pose>0 0 0.24 0 0 0</pose>
      <link name="base_link">
        <inertial><mass>24.0</mass><inertia><ixx>0.18</ixx><iyy>0.28</iyy><izz>0.36</izz></inertia></inertial>
        <collision name="base_collision"><pose>0 0 0.18 0 0 0</pose><geometry><box><size>1.10 0.76 0.36</size></box></geometry></collision>
        <visual name="base_visual"><pose>0 0 0.18 0 0 0</pose><geometry><box><size>1.10 0.76 0.36</size></box></geometry><material><diffuse>0.08 0.28 0.70 1</diffuse></material></visual>
        <visual name="lidar_visual"><pose>0.36 0 0.54 0 0 0</pose><geometry><cylinder><radius>0.11</radius><length>0.11</length></cylinder></geometry><material><diffuse>0.05 0.55 0.32 1</diffuse></material></visual>
        <visual name="camera_visual"><pose>0.58 0 0.42 0 0 0</pose><geometry><box><size>0.14 0.07 0.07</size></box></geometry><material><diffuse>0.05 0.55 0.32 1</diffuse></material></visual>
        <sensor name="lidar" type="gpu_lidar">
          <pose>0.36 0 0.54 0 0 0</pose>
          <topic>/sim/scan</topic>
          <update_rate>10</update_rate>
          <always_on>true</always_on>
          <lidar>
            <scan>
              <horizontal>
                <samples>360</samples>
                <resolution>1</resolution>
                <min_angle>-3.14159265359</min_angle>
                <max_angle>3.14159265359</max_angle>
              </horizontal>
            </scan>
            <range>
              <min>0.08</min>
              <max>12.0</max>
              <resolution>0.01</resolution>
            </range>
          </lidar>
        </sensor>
        <sensor name="imu" type="imu">
          <pose>0 0 0.46 0 0 0</pose>
          <topic>/sim/imu</topic>
          <update_rate>100</update_rate>
          <always_on>true</always_on>
        </sensor>
      </link>
      <link name="left_wheel">
        <pose>0 0.43 0 1.57079632679 0 0</pose>
        <inertial><mass>0.7</mass><inertia><ixx>0.002</ixx><iyy>0.002</iyy><izz>0.002</izz></inertia></inertial>
        <collision name="collision"><geometry><cylinder><radius>0.15</radius><length>0.09</length></cylinder></geometry></collision>
        <visual name="visual"><geometry><cylinder><radius>0.15</radius><length>0.09</length></cylinder></geometry><material><diffuse>0.02 0.02 0.02 1</diffuse></material></visual>
      </link>
      <link name="right_wheel">
        <pose>0 -0.43 0 1.57079632679 0 0</pose>
        <inertial><mass>0.7</mass><inertia><ixx>0.002</ixx><iyy>0.002</iyy><izz>0.002</izz></inertia></inertial>
        <collision name="collision"><geometry><cylinder><radius>0.15</radius><length>0.09</length></cylinder></geometry></collision>
        <visual name="visual"><geometry><cylinder><radius>0.15</radius><length>0.09</length></cylinder></geometry><material><diffuse>0.02 0.02 0.02 1</diffuse></material></visual>
      </link>
      <link name="caster_wheel">
        <pose>-0.4 0 -0.08 0 0 0</pose>
        <collision name="collision"><geometry><sphere><radius>0.08</radius></sphere></geometry></collision>
        <visual name="visual"><geometry><sphere><radius>0.08</radius></sphere></geometry><material><diffuse>0.02 0.02 0.02 1</diffuse></material></visual>
      </link>
      <joint name="left_wheel_joint" type="revolute">
        <parent>base_link</parent><child>left_wheel</child><axis><xyz>0 1 0</xyz></axis>
      </joint>
      <joint name="right_wheel_joint" type="revolute">
        <parent>base_link</parent><child>right_wheel</child><axis><xyz>0 1 0</xyz></axis>
      </joint>
      <joint name="caster_joint" type="fixed">
        <parent>base_link</parent><child>caster_wheel</child>
      </joint>
      <plugin filename="gz-sim-diff-drive-system" name="gz::sim::systems::DiffDrive">
        <left_joint>left_wheel_joint</left_joint>
        <right_joint>right_wheel_joint</right_joint>
        <wheel_separation>0.86</wheel_separation>
        <wheel_radius>0.15</wheel_radius>
        <topic>/cmd_vel</topic>
        <odom_topic>/model/mobile_robot/odometry</odom_topic>
        <frame_id>odom</frame_id>
        <child_frame_id>base_link</child_frame_id>
      </plugin>
    </model>

