    <gui fullscreen="0">
      <!-- Default camera: oblique overview for first-launch screenshots. -->
      <plugin filename="MinimalScene" name="3D View">
        <gz-gui>
          <property type="string" key="state">docked</property>
        </gz-gui>
        <engine>ogre2</engine>
        <scene>scene</scene>
        <ambient_light>0.55 0.57 0.60</ambient_light>
        <background_color>0.80 0.83 0.86</background_color>
        <camera_pose>-8.40 -7.15 8.40 0 0.78 0.72</camera_pose>
