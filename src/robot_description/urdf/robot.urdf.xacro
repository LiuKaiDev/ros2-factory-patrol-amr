<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="mobile_robot">
  <xacro:arg name="use_gazebo" default="false"/>
  <xacro:arg name="use_ros2_control_hardware" default="false"/>
  <xacro:arg name="ros2_control_backend" default="mock"/>
  <xacro:arg name="ros2_control_serial_device" default="/dev/ttyUSB0"/>
  <xacro:arg name="ros2_control_serial_baud" default="115200"/>
  <xacro:arg name="ros2_control_udp_host" default="192.168.1.10"/>
  <xacro:arg name="ros2_control_udp_port" default="9000"/>
  <xacro:arg name="ros2_control_protocol" default="text"/>
  <xacro:arg name="ros2_control_chassis_type" default="diff_drive"/>
  <xacro:property name="base_length" value="0.55"/>
  <xacro:property name="base_width" value="0.38"/>
  <xacro:property name="base_height" value="0.18"/>
  <xacro:property name="wheel_radius" value="0.075"/>
  <xacro:property name="wheel_width" value="0.045"/>
  <xacro:property name="wheel_separation" value="0.43"/>

  <material name="body_blue"><color rgba="0.22 0.30 0.42 1.0"/></material>
  <material name="wheel_black"><color rgba="0.05 0.05 0.06 1.0"/></material>
  <material name="sensor_green"><color rgba="0.20 0.42 0.34 1.0"/></material>

  <link name="base_footprint"/>

  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 ${wheel_radius}" rpy="0 0 0"/>
  </joint>

  <link name="base_link">
    <visual>
      <origin xyz="0 0 ${base_height / 2.0}" rpy="0 0 0"/>
      <geometry><box size="${base_length} ${base_width} ${base_height}"/></geometry>
      <material name="body_blue"/>
    </visual>
    <collision>
      <origin xyz="0 0 ${base_height / 2.0}" rpy="0 0 0"/>
      <geometry><box size="${base_length} ${base_width} ${base_height}"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 ${base_height / 2.0}" rpy="0 0 0"/>
      <mass value="12.0"/>
      <inertia ixx="0.18" ixy="0" ixz="0" iyy="0.28" iyz="0" izz="0.36"/>
    </inertial>
  </link>

  <xacro:macro name="drive_wheel" params="prefix y">
    <link name="${prefix}_wheel">
      <visual>
        <origin xyz="0 0 0" rpy="1.57079632679 0 0"/>
        <geometry><cylinder radius="${wheel_radius}" length="${wheel_width}"/></geometry>
        <material name="wheel_black"/>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="1.57079632679 0 0"/>
        <geometry><cylinder radius="${wheel_radius}" length="${wheel_width}"/></geometry>
      </collision>
      <inertial>
        <mass value="0.7"/>
        <inertia ixx="0.002" ixy="0" ixz="0" iyy="0.002" iyz="0" izz="0.002"/>
      </inertial>
    </link>
    <joint name="${prefix}_wheel_joint" type="continuous">
      <parent link="base_link"/>
      <child link="${prefix}_wheel"/>
      <origin xyz="0 ${y} ${wheel_radius}" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
    </joint>
  </xacro:macro>

  <xacro:drive_wheel prefix="left" y="${wheel_separation / 2.0}"/>
  <xacro:drive_wheel prefix="right" y="${-wheel_separation / 2.0}"/>

  <link name="caster_wheel">
    <visual><geometry><sphere radius="0.04"/></geometry><material name="wheel_black"/></visual>
    <collision><geometry><sphere radius="0.04"/></geometry></collision>
    <inertial><mass value="0.2"/><inertia ixx="0.0002" ixy="0" ixz="0" iyy="0.0002" iyz="0" izz="0.0002"/></inertial>
  </link>
  <joint name="caster_wheel_joint" type="fixed">
    <parent link="base_link"/>
    <child link="caster_wheel"/>
    <origin xyz="-0.2 0 0.035" rpy="0 0 0"/>
  </joint>

  <link name="lidar_link">
    <visual><geometry><cylinder radius="0.055" length="0.055"/></geometry><material name="sensor_green"/></visual>
    <collision><geometry><cylinder radius="0.055" length="0.055"/></geometry></collision>
    <inertial><mass value="0.25"/><inertia ixx="0.0004" ixy="0" ixz="0" iyy="0.0004" iyz="0" izz="0.0004"/></inertial>
  </link>
  <joint name="lidar_joint" type="fixed">
    <parent link="base_link"/>
    <child link="lidar_link"/>
    <origin xyz="0.18 0 0.27" rpy="0 0 0"/>
  </joint>

  <link name="imu_link">
    <visual><geometry><box size="0.05 0.04 0.02"/></geometry><material name="sensor_green"/></visual>
    <collision><geometry><box size="0.05 0.04 0.02"/></geometry></collision>
    <inertial><mass value="0.05"/><inertia ixx="0.00005" ixy="0" ixz="0" iyy="0.00005" iyz="0" izz="0.00005"/></inertial>
  </link>
  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/>
    <child link="imu_link"/>
    <origin xyz="0 0 0.22" rpy="0 0 0"/>
  </joint>

  <link name="camera_link">
    <visual><geometry><box size="0.07 0.035 0.035"/></geometry><material name="sensor_green"/></visual>
    <collision><geometry><box size="0.07 0.035 0.035"/></geometry></collision>
    <inertial><mass value="0.12"/><inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/></inertial>
  </link>
  <joint name="camera_joint" type="fixed">
    <parent link="base_link"/>
    <child link="camera_link"/>
    <origin xyz="0.28 0 0.2" rpy="0 0 0"/>
  </joint>

  <xacro:if value="$(arg use_ros2_control_hardware)">
    <ros2_control name="MobileBaseSystem" type="system">
      <hardware>
        <plugin>robot_hardware/ChassisHardwareInterface</plugin>
        <param name="backend">$(arg ros2_control_backend)</param>
        <param name="serial_device">$(arg ros2_control_serial_device)</param>
        <param name="serial_baud">$(arg ros2_control_serial_baud)</param>
        <param name="udp_host">$(arg ros2_control_udp_host)</param>
        <param name="udp_port">$(arg ros2_control_udp_port)</param>
        <param name="protocol">$(arg ros2_control_protocol)</param>
        <param name="chassis_type">$(arg ros2_control_chassis_type)</param>
        <param name="wheel_diameter_m">0.15</param>
        <param name="wheel_base_m">0.42</param>
        <param name="track_width_m">0.43</param>
      </hardware>
      <joint name="left_wheel_joint">
        <command_interface name="velocity"/>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
      </joint>
      <joint name="right_wheel_joint">
        <command_interface name="velocity"/>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
      </joint>
    </ros2_control>
  </xacro:if>

  <xacro:if value="$(arg use_gazebo)">
    <ros2_control name="MobileBaseSystem" type="system">
      <hardware>
        <plugin>gz_ros2_control/GazeboSimSystem</plugin>
      </hardware>
      <joint name="left_wheel_joint">
        <command_interface name="velocity"/>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
      </joint>
      <joint name="right_wheel_joint">
        <command_interface name="velocity"/>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
      </joint>
    </ros2_control>

    <gazebo>
      <plugin filename="gz_ros2_control-system" name="gz_ros2_control::GazeboSimROS2ControlPlugin">
        <parameters>$(find robot_bringup)/config/controllers.yaml</parameters>
      </plugin>
    </gazebo>

    <gazebo reference="lidar_link">
      <sensor type="gpu_lidar" name="lidar">
        <topic>scan</topic>
        <update_rate>10</update_rate>
        <ray>
          <scan><horizontal><samples>360</samples><resolution>1</resolution><min_angle>-3.14159</min_angle><max_angle>3.14159</max_angle></horizontal></scan>
          <range><min>0.08</min><max>12.0</max><resolution>0.01</resolution></range>
        </ray>
      </sensor>
    </gazebo>

    <gazebo reference="imu_link">
      <sensor type="imu" name="imu">
        <topic>imu</topic>
        <update_rate>100</update_rate>
      </sensor>
    </gazebo>

    <gazebo reference="camera_link">
      <sensor type="camera" name="camera">
        <topic>camera</topic>
        <update_rate>15</update_rate>
        <camera><horizontal_fov>1.2</horizontal_fov><image><width>640</width><height>480</height></image></camera>
      </sensor>
    </gazebo>
  </xacro:if>
</robot>
